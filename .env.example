# =============================================================================
# SwiftReview Pro — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- OpenAI ----
OPENAI_API_KEY=

# ---- Stripe ----
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (create in Stripe Dashboard → Products)
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Allowed Origins (optional, comma-separated) ----
# Additional origins allowed to invoke server actions beyond NEXT_PUBLIC_APP_URL.
# Only needed if you serve from multiple domains (e.g. preview deploys).
# ALLOWED_ORIGINS=https://preview.swiftreviewpro.com

# ---- Resend (transactional email) ----
RESEND_API_KEY=

# ---- Sentry (error monitoring) ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ---- Upstash Redis (rate limiting) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Google Business Profile (OAuth) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Yelp Fusion API ----
YELP_API_KEY=

# ---- Integration Credential Encryption ----
# AES-256-GCM key for encrypting OAuth tokens at rest.
# Generate with: openssl rand -hex 32
INTEGRATION_ENCRYPTION_KEY=

# ---- Cron ----
CRON_SECRET=
